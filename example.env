# Copy this file to .env before running the project.

# Required. Gin listen address for the backend API.
APP_ADDR=:8080

# Required. Public frontend origin used by CORS.
FRONTEND_ORIGIN=http://localhost:5173

# Required. PostgreSQL connection string.
DATABASE_URL=postgres://blog:blog_password@localhost:5432/pg_blog?sslmode=disable

# Required. Redis connection settings. Redis stores statistics, cache and event stream data.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Required. Use a long random value in production, at least 32 bytes.
JWT_SECRET=change-me-to-a-long-random-secret

# Optional. Cookie settings. Set COOKIE_SECURE=true behind HTTPS.
COOKIE_NAME=pg_blog_token
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# Required when OSS upload/sync is enabled.
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-bucket
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_PREFIX=pg-blog

# Optional. When false, files are written only to PostgreSQL and local dev still works.
OSS_ENABLED=false
